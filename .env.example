# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_DB=ncdb
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ============================================
# NEXTCLOUD ADMIN
# ============================================
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============================================
# DOMAIN & SSL
# ============================================
NEXTCLOUD_DOMAIN=example.com
NEXTCLOUD_TRUSTED_DOMAINS=example.com,www.example.com
LETSENCRYPT_EMAIL=admin@example.com
OVERWRITEPROTOCOL=https

# ============================================
# PHP CONFIGURATION
# ============================================
PHP_MEMORY_LIMIT=1024M
PHP_UPLOAD_MAX_FILESIZE=32G
PHP_POST_MAX_SIZE=32G
PHP_MAX_EXECUTION_TIME=7200
PHP_MAX_INPUT_TIME=7200
PHP_OPCACHE_ENABLE=1
PHP_OPCACHE_MEMORY_CONSUMPTION=512
PHP_APCU_ENABLED=1

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================
# CONTAINER PORTS (localhost only)
# ============================================
NEXTCLOUD_HTTP_PORT=8081
NEXTCLOUD_HTTPS_PORT=8443

# ============================================
# BACKUP/MAINTENANCE
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
